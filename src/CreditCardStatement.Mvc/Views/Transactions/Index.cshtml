@model CreditCardStatement.Mvc.ViewModels.TransactionViewModel
@{
    ViewData["Title"] = "Historial de Transacciones";
    var months = System.Globalization.CultureInfo.GetCultureInfo("es-HN").DateTimeFormat.MonthNames;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-danger fw-bold">Historial de Transacciones</h2>
    <div class="d-flex gap-2 align-items-center">
        <span id="ws-status" class="badge bg-secondary">⚡ Conectando...</span>
        <a href="/Purchases/ExportExcel?cardId=@Model.CardId&month=@Model.SelectedMonth&year=@Model.SelectedYear"
           class="btn btn-success">
            📊 Exportar Compras en Excel
        </a>
    </div>
</div>

<div class="card mb-4 border-0 shadow-sm">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-auto">
                <label class="form-label fw-semibold">Mes</label>
                <select name="month" class="form-select">
                    @for (int i = 1; i <= 12; i++)
                    {
                        <option value="@i" selected="@(Model.SelectedMonth == i)">
                            @months[i - 1]
                        </option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label fw-semibold">Año</label>
                <input type="number" name="year" class="form-control"
                       value="@Model.SelectedYear" min="2020" max="2099" />
            </div>
            <input type="hidden" name="cardId" value="@Model.CardId" />
            <div class="col-auto">
                <button type="submit" class="btn btn-danger">Consultar</button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-danger text-white">
        <h5 class="mb-0">Movimientos del Mes</h5>
    </div>
    <div class="card-body p-0">
        @if (!Model.Transactions.Any())
        {
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Fecha</th>
                        <th>Descripción</th>
                        <th>Tipo</th>
                        <th class="text-end">Monto</th>
                    </tr>
                </thead>
                <tbody id="transactions-tbody">
                    <tr id="empty-row">
                        <td colspan="4" class="p-3 text-muted">No hay transacciones para este período.</td>
                    </tr>
                </tbody>
            </table>
        }
        else
        {
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Fecha</th>
                        <th>Descripción</th>
                        <th>Tipo</th>
                        <th class="text-end">Monto</th>
                    </tr>
                </thead>
                <tbody id="transactions-tbody">
                    @foreach (var tx in Model.Transactions)
                    {
                        <tr>
                            <td>@tx.TxDate.ToString("dd/MM/yyyy")</td>
                            <td>@(tx.Description ?? "-")</td>
                            <td>
                                @if (tx.TxType == "PURCHASE")
                                {
                                    <span class="badge bg-danger">Compra</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Pago</span>
                                }
                            </td>
                            <td class="text-end">@tx.Amount.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
<script>
    const apiBaseUrl = "@(ViewBag.ApiBaseUrl ?? "https://localhost:7213")";

    const connection = new signalR.HubConnectionBuilder()
        .withUrl(apiBaseUrl + "/hubs/transactions", {
            withCredentials: true
        })
        .withAutomaticReconnect()
        .build();

    connection.on("NuevaTransaccion", function (tx) {
        const tbody = document.getElementById("transactions-tbody");
        if (!tbody) return;

        const emptyRow = document.getElementById("empty-row");
        if (emptyRow) emptyRow.remove();

        const tipoBadge = tx.txType === "PURCHASE"
            ? "<span class='badge bg-danger'>Compra</span>"
            : "<span class='badge bg-success'>Pago</span>";

        const monto = new Intl.NumberFormat('en-US', {
            style: 'currency',
            currency: 'USD'
        }).format(tx.amount);

        const fila = `
            <tr class="table-warning">
                <td>${tx.txDate}</td>
                <td>${tx.description ?? "-"}</td>
                <td>${tipoBadge}</td>
                <td class="text-end">${monto}</td>
            </tr>`;

        tbody.insertAdjacentHTML("afterbegin", fila);

        setTimeout(() => {
            const filaResaltada = tbody.querySelector(".table-warning");
            if (filaResaltada) filaResaltada.classList.remove("table-warning");
        }, 3000);
    });

    connection.onreconnecting(() => {
        document.getElementById("ws-status").className = "badge bg-warning";
        document.getElementById("ws-status").textContent = "⚡ Reconectando...";
    });

    connection.onreconnected(() => {
        document.getElementById("ws-status").className = "badge bg-success";
        document.getElementById("ws-status").textContent = "⚡ En vivo";
    });

    connection.onclose(() => {
        document.getElementById("ws-status").className = "badge bg-secondary";
        document.getElementById("ws-status").textContent = "⚡ Desconectado";
    });

    connection.start()
        .then(() => {
            document.getElementById("ws-status").className = "badge bg-success";
            document.getElementById("ws-status").textContent = "⚡ En vivo";
        })
        .catch(err => {
            document.getElementById("ws-status").className = "badge bg-danger";
            document.getElementById("ws-status").textContent = "⚡ Sin conexión";
            console.error("Error conectando WebSocket:", err);
        });
</script>
}